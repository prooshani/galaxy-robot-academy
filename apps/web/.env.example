# ============================================================
# Firebase Client SDK — public config (safe to expose in browser)
# Copy this file to .env.local and fill in real values.
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=galaxy-robot-academy.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=galaxy-robot-academy
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=galaxy-robot-academy.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Named Firestore database (enterprise / native, Zurich region)
NEXT_PUBLIC_FIREBASE_DB_ID=galaxy-robot-academy-db

# ============================================================
# Firebase Admin SDK — server ONLY. Never commit real values.
# ============================================================
FIREBASE_ADMIN_PROJECT_ID=galaxy-robot-academy
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-fbsvc@galaxy-robot-academy.iam.gserviceaccount.com
# Keep the surrounding quotes; use literal \n for line breaks.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Named Firestore database used by Admin SDK
FIREBASE_DB_ID=galaxy-robot-academy-db

# ============================================================
# reCAPTCHA Enterprise (bot/abuse scoring on auth)
# ============================================================
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lf-Y04tAAAAALD09UDfNV8StTbnByLX9-HqIgxG
RECAPTCHA_MIN_SCORE=0.5
